<?xml version="1.0" encoding="UTF-8"?>

<web-app version="2.5"
xmlns="http://java.sun.com/xml/ns/javaee"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://java.sun.com/xml/ns/javaee
http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">

<!-- ================= CONTROLLERS ================= -->

<servlet>
    <servlet-name>MainController</servlet-name>
    <servlet-class>controller.MainController</servlet-class>
</servlet>

<servlet>
    <servlet-name>LogoutController</servlet-name>
    <servlet-class>controller.LogoutController</servlet-class>
</servlet>

<servlet>
    <servlet-name>AddressController</servlet-name>
    <servlet-class>controller.AddressController</servlet-class>
</servlet>

<servlet>
    <servlet-name>BookController</servlet-name>
    <servlet-class>controller.BookController</servlet-class>
</servlet>

<servlet>
    <servlet-name>CartController</servlet-name>
    <servlet-class>controller.CartController</servlet-class>
</servlet>

<servlet>
    <servlet-name>CategoryController</servlet-name>
    <servlet-class>controller.CategoryController</servlet-class>
</servlet>

<servlet>
    <servlet-name>DiscountController</servlet-name>
    <servlet-class>controller.DiscountController</servlet-class>
</servlet>

<servlet>
    <servlet-name>NewsController</servlet-name>
    <servlet-class>controller.NewsController</servlet-class>
</servlet>

<servlet>
    <servlet-name>NotificationController</servlet-name>
    <servlet-class>controller.NotificationController</servlet-class>
</servlet>

<servlet>
    <servlet-name>OrderController</servlet-name>
    <servlet-class>controller.OrderController</servlet-class>
</servlet>

<servlet>
    <servlet-name>PaymentController</servlet-name>
    <servlet-class>controller.PaymentController</servlet-class>
</servlet>

<servlet>
    <servlet-name>PublisherController</servlet-name>
    <servlet-class>controller.PublisherController</servlet-class>
</servlet>

<servlet>
    <servlet-name>ReviewController</servlet-name>
    <servlet-class>controller.ReviewController</servlet-class>
</servlet>

<servlet>
    <servlet-name>RoleController</servlet-name>
    <servlet-class>controller.RoleController</servlet-class>
</servlet>

<servlet>
    <servlet-name>ShiftController</servlet-name>
    <servlet-class>controller.ShiftController</servlet-class>
</servlet>

<servlet>
    <servlet-name>ShippingProviderController</servlet-name>
    <servlet-class>controller.ShippingProviderController</servlet-class>
</servlet>

<servlet>
    <servlet-name>WishlistController</servlet-name>
    <servlet-class>controller.WishlistController</servlet-class>
</servlet>

<!-- ================= SERVLET MAPPING ================= -->

<servlet-mapping>
    <servlet-name>MainController</servlet-name>
    <url-pattern>/MainController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>LogoutController</servlet-name>
    <url-pattern>/LogoutController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>AddressController</servlet-name>
    <url-pattern>/AddressController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>BookController</servlet-name>
    <url-pattern>/BookController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>CartController</servlet-name>
    <url-pattern>/CartController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>CategoryController</servlet-name>
    <url-pattern>/CategoryController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>DiscountController</servlet-name>
    <url-pattern>/DiscountController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>NewsController</servlet-name>
    <url-pattern>/NewsController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>NotificationController</servlet-name>
    <url-pattern>/NotificationController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>OrderController</servlet-name>
    <url-pattern>/OrderController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>PaymentController</servlet-name>
    <url-pattern>/PaymentController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>PublisherController</servlet-name>
    <url-pattern>/PublisherController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>ReviewController</servlet-name>
    <url-pattern>/ReviewController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>RoleController</servlet-name>
    <url-pattern>/RoleController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>ShiftController</servlet-name>
    <url-pattern>/ShiftController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>ShippingProviderController</servlet-name>
    <url-pattern>/ShippingProviderController</url-pattern>
</servlet-mapping>

<servlet-mapping>
    <servlet-name>WishlistController</servlet-name>
    <url-pattern>/WishlistController</url-pattern>
</servlet-mapping>

<!-- ================= SESSION ================= -->

<session-config>
    <session-timeout>30</session-timeout>
</session-config>

<!-- ================= HOME PAGE ================= -->

<welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
</welcome-file-list>

</web-app>
